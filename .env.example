# Pinata dedicated gateway — find it in Pinata dashboard → Gateways.
# (Looks like: your-name-123.mypinata.cloud)
VITE_PINATA_GATEWAY=your-gateway.mypinata.cloud

# Gateway access token — Pinata → Gateways → ⋯ → Gateway Access Controls → create a key.
VITE_PINATA_GATEWAY_TOKEN=your_gateway_access_token
